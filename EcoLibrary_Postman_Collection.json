                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Zéro Déchet (Mise à jour)\",\n    \"slug\": \"zero-dechet-v2\",\n    \"description\": \"Nouvelle description.\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }

                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"category_id\": 1,\n    \"title\": \"Le Magasin Zéro Déchet\",\n    \"author\": \"Jean Dupont\",\n    \"slug\": \"le-magasin-zero-dechet\",\n    \"description\": \"Un livre passionnant.\"\n}",

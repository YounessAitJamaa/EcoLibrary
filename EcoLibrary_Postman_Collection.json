{
    "info": {
        "_postman_id": "ecolibrary-api-collection",
        "name": "EcoLibrary API",
        "description": "Documentation API pour la gestion d'une collection de livres classés par catégories (EcoLibrary).",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Authentification",
            "description": "Endpoints pour gérer l'inscription, la connexion et la déconnexion.",
            "item": [
                {
                    "name": "Inscription (Register)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Lecteur Test\",\n    \"email\": \"lecteur@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/register",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "register"
                            ]
                        }
                    }
                },
                {
                    "name": "Connexion (Login)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"lecteur@example.com\",\n    \"password\": \"password123\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "login"
                            ]
                        }
                    }
                },
                {
                    "name": "Déconnexion (Logout)",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{bearer_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/logout",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "logout"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Lecteurs (Public)",
            "description": "Endpoints accessibles à tous pour consulter le catalogue.",
            "item": [
                {
                    "name": "Lister les Catégories",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/category",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "category"
                            ]
                        }
                    }
                },
                {
                    "name": "Voir une Catégorie (avec ses livres)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/category/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "category",
                                "1"
                            ]
                        }
                    }
                },
                {
                    "name": "Lister / Rechercher des Livres",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/books?search=jardin&available=1&sort=popular",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "books"
                            ],
                            "query": [
                                {
                                    "key": "category_id",
                                    "value": "1",
                                    "description": "Filtrer par ID de catégorie",
                                    "disabled": true
                                },
                                {
                                    "key": "search",
                                    "value": "jardin",
                                    "description": "Rechercher dans le titre ou le nom de la catégorie"
                                },
                                {
                                    "key": "available",
                                    "value": "1",
                                    "description": "Afficher uniquement les livres avec au moins un exemplaire disponible"
                                },
                                {
                                    "key": "sort",
                                    "value": "popular",
                                    "description": "Trier par : 'popular' ou 'recent'"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Voir un Livre (Incrémente les vues)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/books/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "books",
                                "1"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Administrateur",
            "description": "Gestion du catalogue et statistiques. Nécessite le rôle 'admin'.",
            "item": [
                {
                    "name": "Statistiques (Dashboard)",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{bearer_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/admin/stats",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "stats"
                            ]
                        }
                    }
                },
